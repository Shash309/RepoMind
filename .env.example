# ─── Root .env.example ───────────────────────────────────────────────────────
# Copy values into backend/.env and/or frontend/.env.local as appropriate.
# See backend/.env.example and frontend/.env.example for per-package docs.

# ── Backend vars (copy to backend/.env on Render) ────────────────────────────
PORT=3001
GROQ_API_KEY=your_groq_api_key_here
COHERE_API_KEY=your_cohere_api_key_here
MISTRAL_API_KEY=your_mistral_api_key_here                        # Optional – only needed for Mistral models
OPENAI_API_KEY=your_openai_api_key_here                        # Optional – only needed for OpenAI models
FRONTEND_URL=https://your-app.vercel.app   # Set to your deployed Vercel URL

# ── Frontend vars (copy to frontend/.env.local for local dev) ─────────────────
# Leave empty locally — next.config.mjs falls back to http://localhost:3001
# In Vercel dashboard, set this to your Render backend URL (no trailing slash, no /api)
NEXT_PUBLIC_API_URL=https://repomind-7jzw.onrender.com
